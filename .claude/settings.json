{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(php *)",
      "Bash(./vendor/bin/pest *)",
      "Bash(composer *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(gh *)",
      "Bash(date *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(sqlite3 *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(.env)"
    ]
  }
}
