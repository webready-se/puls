{
    "name": "webready/puls",
    "description": "Cookieless analytics",
    "license": "MIT",
    "type": "project",
    "authors": [
        {
            "name": "Nicklas Jarnesjö",
            "email": "nicklas@webready.se"
        }
    ],
    "require-dev": {
        "pestphp/pest": "*"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": "git config core.hooksPath scripts/hooks",
        "post-update-cmd": "git config core.hooksPath scripts/hooks"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
