# Auto-generated app key — used for visitor hashing.
# Generate with: php puls key:generate
APP_KEY=

# Allowed origins for CORS on collect endpoint (comma-separated).
# Empty = allow all (fine for same-domain tracking).
# Example: https://lillabosgarden.se,https://odlingsguiden.se
ALLOWED_ORIGINS=

# Database path (relative to project root)
DB_PATH=data/puls.sqlite

# Session lifetime in seconds (default: 30 days)
SESSION_LIFETIME=2592000

# Brute-force protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
