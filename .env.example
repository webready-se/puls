# Auto-generated app key — used for visitor hashing.
# Generate with: php puls key:generate
APP_KEY=

# Allowed origins for tracking (comma-separated domains).
# Empty = allow all (fine for same-domain tracking).
# Subdomains are included automatically (webready.se also allows www.webready.se, app.webready.se, etc.)
# Example: webready.se,example.com
ALLOWED_ORIGINS=

# Database path (relative to project root)
DB_PATH=data/puls.sqlite

# Users file path (relative to project root)
USERS_FILE=users.json

# Session lifetime in seconds (default: 30 days)
SESSION_LIFETIME=2592000

# Brute-force protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
