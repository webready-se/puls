#!/usr/bin/env php
<?php
/**
 * Puls CLI
 *
 * Usage:
 *   php puls key:generate                        Generate a new APP_KEY
 *   php puls user:add <name> [--sites=a,b]       Add a user
 *   php puls user:edit <name>                    Edit user (sites, password)
 *   php puls user:remove <name>                  Remove a user
 *   php puls user:list                           List all users
 *   php puls sites:list                          List all tracked sites
 *   php puls sites:rename <old> <new>              Rename a site
 */

$config = require __DIR__ . '/config.php';
$command = $argv[1] ?? 'help';

match ($command) {
    'key:generate' => generateKey(),
    'user:add'     => userAdd($config, $argv[2] ?? null, $argv),
    'user:edit'    => userEdit($config, $argv[2] ?? null),
    'user:remove'  => userRemove($config['users_file'], $argv[2] ?? null),
    'user:list'    => userList($config['users_file']),
    'sites:list'   => sitesList($config['db_path']),
    'sites:rename' => sitesRename($config, $argv[2] ?? null, $argv[3] ?? null),
    default        => printHelp(),
};

// =====================================================================
// key:generate
// =====================================================================

function generateKey(): void
{
    $key = 'base64:' . base64_encode(random_bytes(32));
    $envFile = __DIR__ . '/.env';

    if (!file_exists($envFile)) {
        $example = __DIR__ . '/.env.example';
        if (file_exists($example)) {
            copy($example, $envFile);
        } else {
            file_put_contents($envFile, "APP_KEY=\n");
        }
    }

    $contents = file_get_contents($envFile);

    if (preg_match('/^APP_KEY=.*$/m', $contents)) {
        $contents = preg_replace('/^APP_KEY=.*$/m', "APP_KEY={$key}", $contents);
    } else {
        $contents = "APP_KEY={$key}\n" . $contents;
    }

    file_put_contents($envFile, $contents);
    echo "APP_KEY set: {$key}\n";
}

// =====================================================================
// user:add
// =====================================================================

function userAdd(array $config, ?string $username, array $argv): void
{
    if (!$username) {
        echo "Usage: php puls user:add <username> [--sites=a,b]\n";
        exit(1);
    }

    $users = loadUsers($config['users_file']);

    if (isset($users[$username])) {
        echo "User '{$username}' already exists. Use user:edit to modify.\n";
        exit(1);
    }

    echo "Password for {$username}: ";
    system('stty -echo');
    $password = trim(fgets(STDIN));
    system('stty echo');
    echo "\n";

    if (strlen($password) < 8) {
        echo "Password must be at least 8 characters.\n";
        exit(1);
    }

    // Parse --sites flag
    $sites = null;
    foreach ($argv as $arg) {
        if (str_starts_with($arg, '--sites=')) {
            $sites = array_values(array_filter(explode(',', substr($arg, 8))));
        }
    }

    // Interactive site selection if --sites not provided
    if ($sites === null) {
        $sites = interactiveSiteSelect($config['db_path'], []);
    }

    $users[$username] = [
        'password' => password_hash($password, PASSWORD_BCRYPT, ['cost' => 12]),
        'sites' => $sites,
    ];

    saveUsers($config['users_file'], $users);
    $scope = $sites ? implode(', ', $sites) : 'alla sajter';
    echo "User '{$username}' added (access: {$scope}).\n";
}

// =====================================================================
// user:edit
// =====================================================================

function userEdit(array $config, ?string $username): void
{
    if (!$username) {
        echo "Usage: php puls user:edit <username>\n";
        exit(1);
    }

    $users = loadUsers($config['users_file']);

    if (!isset($users[$username])) {
        echo "User '{$username}' not found.\n";
        exit(1);
    }

    $user = $users[$username];
    $currentSites = $user['sites'] ?? [];
    $scope = $currentSites ? implode(', ', $currentSites) : 'alla sajter';
    echo "Editing user '{$username}' (current access: {$scope})\n\n";

    // Site selection
    $sites = interactiveSiteSelect($config['db_path'], $currentSites);

    // Password change
    echo "Change password? (y/N): ";
    $answer = strtolower(trim(fgets(STDIN)));

    if ($answer === 'y' || $answer === 'j') {
        echo "New password: ";
        system('stty -echo');
        $password = trim(fgets(STDIN));
        system('stty echo');
        echo "\n";

        if (strlen($password) < 8) {
            echo "Password must be at least 8 characters.\n";
            exit(1);
        }

        $user['password'] = password_hash($password, PASSWORD_BCRYPT, ['cost' => 12]);
        echo "Password updated.\n";
    }

    $user['sites'] = $sites;
    $users[$username] = $user;

    saveUsers($config['users_file'], $users);
    $scope = $sites ? implode(', ', $sites) : 'alla sajter';
    echo "User '{$username}' updated (access: {$scope}).\n";
}

// =====================================================================
// user:remove
// =====================================================================

function userRemove(string $file, ?string $username): void
{
    if (!$username) {
        echo "Usage: php puls user:remove <username>\n";
        exit(1);
    }

    $users = loadUsers($file);

    if (!isset($users[$username])) {
        echo "User '{$username}' not found.\n";
        exit(1);
    }

    unset($users[$username]);
    saveUsers($file, $users);
    echo "User '{$username}' removed.\n";
}

// =====================================================================
// user:list
// =====================================================================

function userList(string $file): void
{
    $users = loadUsers($file);

    if (empty($users)) {
        echo "No users configured. Run: php puls user:add <username>\n";
        return;
    }

    echo sprintf("%-20s %s\n", 'USERNAME', 'SITES');
    echo str_repeat('-', 50) . "\n";
    foreach ($users as $name => $data) {
        $sites = !empty($data['sites']) ? implode(', ', $data['sites']) : 'alla';
        echo sprintf("%-20s %s\n", $name, $sites);
    }
}

// =====================================================================
// sites:list
// =====================================================================

function sitesList(string $dbPath): void
{
    if (!file_exists($dbPath)) {
        echo "No database found. Start tracking to create it.\n";
        exit(1);
    }

    $db = new PDO('sqlite:' . $dbPath);
    $db->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    $stmt = $db->query("
        SELECT
            p.site,
            MIN(p.created_at) as first_seen,
            MAX(p.created_at) as last_seen,
            COUNT(*) as pageviews,
            COUNT(DISTINCT p.visitor_hash) as visitors,
            COALESCE(bl.broken_links, 0) as broken_links
        FROM pageviews p
        LEFT JOIN (
            SELECT site, COUNT(*) as broken_links
            FROM broken_links
            GROUP BY site
        ) bl ON bl.site = p.site
        GROUP BY p.site
        ORDER BY p.site
    ");

    $sites = $stmt->fetchAll(PDO::FETCH_ASSOC);

    if (empty($sites)) {
        echo "No sites tracked yet.\n";
        return;
    }

    $col = 22;
    echo mbPad('SITE', $col) . sprintf("%-12s %-12s %10s %10s %8s\n",
        'SINCE', 'LAST SEEN', 'PAGEVIEWS', 'VISITORS', 'BROKEN');
    echo str_repeat('─', 78) . "\n";

    foreach ($sites as $s) {
        echo mbPad($s['site'], $col) . sprintf("%-12s %-12s %10s %10s %8s\n",
            substr($s['first_seen'], 0, 10),
            substr($s['last_seen'], 0, 10),
            number_format($s['pageviews']),
            number_format($s['visitors']),
            $s['broken_links'] ?: '-'
        );
    }

    echo "\n" . count($sites) . " site(s) tracked.\n";
}

// =====================================================================
// sites:rename
// =====================================================================

function sitesRename(array $config, ?string $oldName, ?string $newName): void
{
    if (!$oldName || !$newName) {
        echo "Usage: php puls sites:rename <old-name> <new-name>\n";
        exit(1);
    }

    if ($oldName === $newName) {
        echo "Old and new name are the same.\n";
        exit(1);
    }

    $dbPath = $config['db_path'];
    if (!file_exists($dbPath)) {
        echo "No database found.\n";
        exit(1);
    }

    $db = new PDO('sqlite:' . $dbPath);
    $db->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    // Check that old site exists
    $stmt = $db->prepare('SELECT COUNT(*) FROM pageviews WHERE site = ?');
    $stmt->execute([$oldName]);
    $count = $stmt->fetchColumn();

    if ($count === 0) {
        echo "Site '{$oldName}' not found in database.\n";
        exit(1);
    }

    // Check that new name doesn't already exist
    $stmt = $db->prepare('SELECT COUNT(*) FROM pageviews WHERE site = ?');
    $stmt->execute([$newName]);
    if ($stmt->fetchColumn() > 0) {
        echo "Site '{$newName}' already exists. Cannot rename to an existing site.\n";
        exit(1);
    }

    // Rename in all tables
    $db->beginTransaction();

    $tables = ['pageviews', 'bot_visits', 'broken_links'];
    foreach ($tables as $table) {
        $stmt = $db->prepare("UPDATE {$table} SET site = ? WHERE site = ?");
        $stmt->execute([$newName, $oldName]);
        $affected = $stmt->rowCount();
        if ($affected > 0) {
            echo "  {$table}: {$affected} rows updated\n";
        }
    }

    $db->commit();

    // Update users.json
    $usersFile = $config['users_file'];
    $users = loadUsers($usersFile);
    $usersUpdated = 0;

    foreach ($users as &$user) {
        if (!empty($user['sites']) && in_array($oldName, $user['sites'])) {
            $user['sites'] = array_values(array_map(
                fn($s) => $s === $oldName ? $newName : $s,
                $user['sites']
            ));
            $usersUpdated++;
        }
    }
    unset($user);

    if ($usersUpdated > 0) {
        saveUsers($usersFile, $users);
        echo "  users.json: {$usersUpdated} user(s) updated\n";
    }

    echo "\nRenamed '{$oldName}' → '{$newName}'.\n";
}

// =====================================================================
// Helpers
// =====================================================================

function printHelp(): void
{
    echo <<<'HELP'
    Puls CLI

    Usage:
      php puls key:generate                    Generate a new APP_KEY
      php puls user:add <name> [--sites=a,b]   Add a user
      php puls user:edit <name>                Edit user (sites, password)
      php puls user:remove <name>              Remove a user
      php puls user:list                       List all users
      php puls sites:list                      List all tracked sites
      php puls sites:rename <old> <new>        Rename a site

    Options:
      --sites    Comma-separated list of sites the user can access.
                 Omit for access to all sites.

    HELP;
    echo "\n";
}

function mbPad(string $str, int $width): string
{
    $pad = $width - mb_strlen($str);
    return $str . ($pad > 0 ? str_repeat(' ', $pad) : '');
}

function loadUsers(string $file): array
{
    if (!file_exists($file)) return [];
    return json_decode(file_get_contents($file), true) ?: [];
}

function saveUsers(string $file, array $users): void
{
    file_put_contents($file, json_encode($users, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE));
}

function getTrackedSites(string $dbPath): array
{
    if (!file_exists($dbPath)) return [];

    $db = new PDO('sqlite:' . $dbPath);
    $db->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    $stmt = $db->query('SELECT DISTINCT site FROM pageviews ORDER BY site');
    return $stmt->fetchAll(PDO::FETCH_COLUMN);
}

function interactiveSiteSelect(string $dbPath, array $currentSites): array
{
    $availableSites = getTrackedSites($dbPath);

    if (empty($availableSites)) {
        echo "No sites in database yet. Use --sites=name to assign manually.\n";
        echo "Grant access to all sites? (Y/n): ";
        $answer = strtolower(trim(fgets(STDIN)));
        return ($answer === 'n') ? [] : [];
    }

    echo "Available sites:\n";
    echo "  0) All sites (admin)\n";
    foreach ($availableSites as $i => $site) {
        $marker = in_array($site, $currentSites) ? ' *' : '';
        echo sprintf("  %d) %s%s\n", $i + 1, $site, $marker);
    }

    if ($currentSites) {
        echo "\n  * = current access\n";
    }

    echo "\nSelect sites (comma-separated numbers, 0 for all): ";
    $input = trim(fgets(STDIN));

    if ($input === '' || $input === '0') {
        return [];
    }

    $selected = [];
    $numbers = array_map('trim', explode(',', $input));
    foreach ($numbers as $num) {
        $idx = (int) $num - 1;
        if ($idx >= 0 && $idx < count($availableSites)) {
            $selected[] = $availableSites[$idx];
        }
    }

    if (empty($selected)) {
        echo "No valid selection. Granting access to all sites.\n";
        return [];
    }

    return $selected;
}
